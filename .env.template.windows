# DepMap Database Configuration Template (Windows)
# Copy this file to .env and customize the values as needed
# Use forward slashes or double backslashes in paths (e.g. C:/Users/you/.depmap or C:\\Users\\you\\.depmap)

# Environment settings
DEPMAP_ENV=development
DEPMAP_DEBUG=false

# Logging configuration
DEPMAP_LOG_LEVEL=INFO
DEPMAP_LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(filename)s:%(lineno)d - %(message)s"
DEPMAP_ENABLE_CONSOLE_LOGGING=true
DEPMAP_ENABLE_FILE_LOGGING=false
DEPMAP_LOG_FILE_PATH=logs/depmap-db.log
DEPMAP_LOG_MAX_BYTES=1048576
DEPMAP_LOG_BACKUP_COUNT=5

# Database settings
# Example: DEPMAP_DATABASE__PATH=C:/Users/YourName/.depmap/depmap.duckdb
DEPMAP_DATABASE__PATH=data/depmap.duckdb
DEPMAP_DATABASE__MEMORY=false
DEPMAP_DATABASE__THREADS=4
DEPMAP_DATABASE__MAX_MEMORY=2GB

# DepMap download settings
DEPMAP_DEPMAP__BASE_URL=https://depmap.org/portal/api/download/files
DEPMAP_DEPMAP__DATASETS_URL=https://depmap.org/portal/api/download/datasets
# Example: DEPMAP_DEPMAP__CACHE_DIR=C:/Users/YourName/.depmap/cache
DEPMAP_DEPMAP__CACHE_DIR=data/cache
DEPMAP_DEPMAP__MAX_RETRIES=3
DEPMAP_DEPMAP__TIMEOUT_SECONDS=300
DEPMAP_DEPMAP__BATCH_SIZE=10000
DEPMAP_DEPMAP__RELEASE_LABEL=DepMap Public 25Q3
DEPMAP_DEPMAP__VERIFY_CHECKSUMS=true
